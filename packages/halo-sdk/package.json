{
  "name": "@halo/sdk",
  "version": "0.0.1",
  "description": "Halo SDK — wrap any Solana transaction with hardware-attested signing on the Seeker via Seed Vault + SAS attestation issuance.",
  "license": "Apache-2.0",
  "author": "Pratik Kale <pratikkale7661@gmail.com>",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@halo/detector": "workspace:*",
    "@solana/web3.js": "^1.95.3"
  },
  "peerDependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@solana-mobile/mobile-wallet-adapter-protocol-web3js": "^2.1.3"
  },
  "peerDependenciesMeta": {
    "@solana-mobile/mobile-wallet-adapter-protocol-web3js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "keywords": [
    "solana",
    "solana-mobile",
    "seeker",
    "seed-vault",
    "attestation",
    "sas",
    "wallet-security",
    "halo"
  ],
  "publishConfig": {
    "access": "public"
  }
}
